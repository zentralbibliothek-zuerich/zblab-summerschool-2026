      "source": [
        "## Inspect the results"
      ],
      "metadata": {
        "id": "2J3exAImZpXx"
      },
      "id": "2J3exAImZpXx"
    },
    {
      "cell_type": "markdown",
      "source": [
        "### OCR Quality Distribution over time"
      ],
      "metadata": {
        "id": "lDEzkPb4d7tL"
      },
      "id": "lDEzkPb4d7tL"
    },
    {
      "cell_type": "code",
      "source": [
        "import numpy as np\n",
        "\n",
        "# Define number of tiers\n",
        "N = 10\n",
        "bins = np.linspace(0, 1, N + 1)\n",
        "tier_labels = [f\"{bins[i]:.1f}-{bins[i+1]:.1f}\" for i in range(N)]\n",
        "\n",
        "raw_df[\"quality_tier\"] = pd.cut(\n",
        "    raw_df[\"ocr_quality\"],\n",
        "    bins=bins,\n",
        "    labels=tier_labels,\n",
        "    include_lowest=True\n",
        ")"
      ],
      "metadata": {
        "id": "9wSS9d37ZyRD"
      },
      "id": "9wSS9d37ZyRD",
      "execution_count": 49,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# Group by year and quality tier, then count occurrences\n",
        "df_grouped = raw_df.groupby(['year', 'quality_tier'], observed=False).size().unstack(fill_value=0)\n",
        "full_index = range(df_grouped.index.min(), df_grouped.index.max() + 1)\n",
        "df_grouped = df_grouped.reindex(full_index, fill_value=0)\n",
        "\n",
        "cmap = plt.cm.RdYlGn\n",
        "colors = {label: cmap(i / (N - 1)) for i, label in enumerate(tier_labels)}\n",
        "\n",
        "# Plot the stacked bar chart\n",
        "ax = df_grouped.plot(kind='area', stacked=True, figsize=(15, 7),\n",
        "                         color=[colors[col] for col in df_grouped.columns]\n",
        ")\n",
        "\n",
        "# Add title and labels\n",
        "plt.title('OCR Quality Tiers Development Over Years (Stacked Bar Chart)')\n",
        "plt.xlabel('Year')\n",
        "plt.ylabel('Number of Articles')\n",
        "plt.legend(title='Quality Tier')\n",
        "plt.xticks(rotation=45, ha='right')\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 562
        },
        "id": "uEyfWspla5CG",
